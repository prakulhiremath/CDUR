    print('='*60)
    for budget in BUDGETS:
        print(f"\n  Budget: {budget['label']} (max_tokens={budget['max_tokens']})")
        for q in QUESTIONS:
            answer, conf, _ = query_model(q["q"], budget, model["id"])
            corr = int(is_correct(answer, q["a"]))
            results.append({
                "model":        model["label"],
                "budget":       budget["label"],
                "max_tokens":   budget["max_tokens"],
                "question":     q["q"][:55],
                "tier":         q["tier"],
                "trap":         q["trap"],
                "expected":     q["a"],
                "predicted":    answer,
                "confidence":   conf,
                "correct":      corr,
            })
            status = "✓" if corr else "✗"
            print(f"    {status} conf={conf:.2f} | {q['q'][:48]} | Got: {answer[:18]}")
            time.sleep(0.3)   # avoid rate limit

