        sub = df[(df["model"]==model["label"]) & (df["budget"]==budget["label"])]
        if len(sub)==0: continue
        acc  = round(sub["correct"].mean(), 3)
        conf = round(sub["confidence"].mean(), 3)
        ece, _ = binned_ece(sub["confidence"].tolist(), sub["correct"].tolist())
        over = round(conf - acc, 3)
        tag  = "OVERCONF" if over>0.05 else ("underconf" if over<-0.05 else "calibrated")
        summary_rows.append({"model": model["label"], "budget": budget["label"],
                              "acc": acc, "conf": conf, "ece": ece, "overconf": over})
        print(f"{model['label']:<18} {budget['label']:<22} {acc:>6} {conf:>6} {ece:>7} {over:>8}  {tag}")
    print()

